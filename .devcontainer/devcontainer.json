{
  "name": "dbt Group Training - BNG (Databricks)",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "root",
  "forwardPorts": [8080, 5000],
  "postCreateCommand": "bash scripts/install_dependencies.sh",
  "containerEnv": {
    // Databricks connection for the BNG training, hosted in Xebia's
    // training Databricks workspace. Host, SQL warehouse path and catalog
    // are pre-configured. The access token is NOT stored here: it is read
    // from a local, git-ignored .env file (see .env.example and the README).
    "DATABRICKS_HOST": "adb-7405616653622888.8.azuredatabricks.net",
    "DATABRICKS_HTTP_PATH": "/sql/1.0/warehouses/9155f778a2d0c7d3",
    "DATABRICKS_CATALOG": "bng_databricks_workspace",
    "DBT_PROFILES_DIR": "/root/.dbt"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "innoverio.vscode-dbt-power-user",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "files.associations": {
          "*.yaml": "jinja-yaml",
          "*.yml": "jinja-yaml",
          "*.md": "jinja-md"
        },
        "markdown.preview.openMarkdownLinks": "inPreview",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "dbt.dbtPythonPath": "/usr/local/bin/python3",
        "dbt.profilesDir": "/root/.dbt",
        "dbt.queryLimit": 100,
        "dbt.runDbtCommandsInTerminal": true,
        "dbt.projectPath": "${containerWorkspaceFolder}/jaffle_shop"
      }
    }
  }
}
