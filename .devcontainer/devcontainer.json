{
  "name": "dbt Group Training - DuckDB",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "root",
  "forwardPorts": [8080, 5000],
  "postCreateCommand": "bash scripts/install_dependencies.sh",
  "remoteEnv": {
    "PATH": "${containerWorkspaceFolder}/.venv/bin:${containerEnv:PATH}"
  },
  "remoteEnv": {
    "PATH": "${containerWorkspaceFolder}/.venv/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "innoverio.vscode-dbt-power-user",
        "redhat.vscode-yaml",
        "mechatroner.rainbow-csv"
      ],
      "settings": {
        "files.associations": {
          "*.yaml": "jinja-yaml",
          "*.yml": "jinja-yaml",
          "*.md": "jinja-md"
        },
        "markdown.preview.openMarkdownLinks": "inPreview",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "dbt.dbtPythonPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "dbt.profilesDir": "${containerWorkspaceFolder}/jaffle_shop",
        "dbt.queryLimit": 100,
        "dbt.runDbtCommandsInTerminal": true,
        "dbt.projectPath": "${containerWorkspaceFolder}/jaffle_shop"
      }
    }
  }
}
