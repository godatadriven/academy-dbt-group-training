{
  "name": "dbt Group Training - Databricks",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "root",
  "forwardPorts": [8080, 5000],
  "postCreateCommand": "bash scripts/install_dependencies.sh",
  "containerEnv": {
    "DATABRICKS_HOST": "${localEnv:DATABRICKS_HOST}",
    "DATABRICKS_HTTP_PATH": "${localEnv:DATABRICKS_HTTP_PATH}",
    "DATABRICKS_TOKEN": "${localEnv:DATABRICKS_TOKEN}",
    "DATABRICKS_SCHEMA": "dbt_dev",
    "DATABRICKS_CATALOG": "hive_metastore",
    "DBT_PROFILES_DIR": "/root/.dbt"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "innoverio.vscode-dbt-power-user",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "files.associations": {
          "*.yaml": "jinja-yaml",
          "*.yml": "jinja-yaml",
          "*.md": "jinja-md"
        },
        "markdown.preview.openMarkdownLinks": "inPreview",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "dbt.dbtPythonPath": "/usr/local/bin/python3",
        "dbt.dbtPath": "/root/.local/bin/dbt",
        "dbt.profilesDir": "/root/.dbt",
        "dbt.queryLimit": 100,
        "dbt.runDbtCommandsInTerminal": true,
        "dbt.projectPath": "${containerWorkspaceFolder}/jaffle_shop"
      }
    }
  }
}